{
  "name": "busted-demo",
  "version": "1.0.0",
  "description": "Security demo app",
  "author": "Bjorn Mijs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "com.busted.demo",
    "productName": "Busted Demo",

    "protocols": [
      {
        "name": "Busted Demo Protocol",
        "schemes": ["m1jsdemo"]
      }
    ],

    "win": {
      "icon": "checked-checkbox-64.ico",
      "target": ["nsis", "portable"],
      "requestedExecutionLevel": "requireAdministrator"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Busted Demo"
    },

    "directories": {
      "output": "dist"
    }
  }
}